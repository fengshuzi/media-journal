{
  "name": "media-journal",
  "version": "1.1.2",
  "description": "Track books, movies, TV, and shows from daily notes with tags, comments, and monthly stats.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run lint && node esbuild.config.mjs production && cp manifest.json styles.css config.json dist/",
    "deploy": "npm run build && node deploy.mjs",
    "release": "node release.mjs",
    "lint": "eslint \"**/*.{ts,tsx}\""
  },
  "keywords": [
    "obsidian",
    "plugin",
    "video",
    "movie",
    "tv"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "^5.0.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "typescript": "^5.9.3",
    "eslint": "^9.39.4",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "typescript-eslint": "^8.58.2"
  }
}
